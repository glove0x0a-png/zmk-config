#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/led/led.h>
#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
    chosen {
        zmk,physical-layout = &glove0x0a_left_layout;
    };

    /* 左手: 20キーのダイレクトスキャン (direct scan) */
    left_transform: matrix_transform_left {
        compatible = "zmk,matrix-transform";
        rows = <20>;
        columns = <1>;
        map = <
            RC(0,0)  RC(1,0)  RC(2,0)  RC(3,0)  RC(4,0)
            RC(5,0)  RC(6,0)  RC(7,0)  RC(8,0)  RC(9,0)
            RC(10,0) RC(11,0) RC(12,0) RC(13,0) RC(14,0)
            RC(15,0) RC(16,0) RC(17,0) RC(18,0) RC(19,0)
        >;
    };

    kscan_left: kscan {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;

        /* XIAO BLE Plus の物理ピン割り当てに合わせて 20 本を列挙する
           コメントは D番号 / 実チップピン を示す */
        input-gpios =
            <&gpio0  2 GPIO_ACTIVE_HIGH>, /*  0: D0  P0.02 */
            <&gpio0  3 GPIO_ACTIVE_HIGH>, /*  1: D1  P0.03 */
            <&gpio0 28 GPIO_ACTIVE_HIGH>, /*  2: D2  P0.28 */
            <&gpio0 29 GPIO_ACTIVE_HIGH>, /*  3: D3  P0.29 */
            <&gpio0  4 GPIO_ACTIVE_HIGH>, /*  4: D4  P0.04 (I2C SDA) */
            <&gpio0  5 GPIO_ACTIVE_HIGH>, /*  5: D5  P0.05 (I2C SCL) */
            <&gpio1 11 GPIO_ACTIVE_HIGH>, /*  6: D6  P1.11 */
            <&gpio1 12 GPIO_ACTIVE_HIGH>, /*  7: D7  P1.12 */
            <&gpio1 13 GPIO_ACTIVE_HIGH>, /*  8: D8  P1.13 */
            <&gpio1 14 GPIO_ACTIVE_HIGH>, /*  9: D9  P1.14 */
            <&gpio1 15 GPIO_ACTIVE_HIGH>, /* 10: D10 P1.15 */
            <&gpio0  6 GPIO_ACTIVE_HIGH>, /* 11: D11 P0.06 */
            <&gpio0  7 GPIO_ACTIVE_HIGH>, /* 12: D12 P0.07 */
            <&gpio0  8 GPIO_ACTIVE_HIGH>, /* 13: D13 P0.08 */
            <&gpio0  9 GPIO_ACTIVE_HIGH>, /* 14: D14 P0.09 */
            <&gpio0 10 GPIO_ACTIVE_HIGH>, /* 15: D15 P0.10 */
            <&gpio0 31 GPIO_ACTIVE_HIGH>, /* 16: D16 P0.31 */
            <&gpio0 30 GPIO_ACTIVE_HIGH>, /* 17: D17 P0.30 */
            <&gpio0 26 GPIO_ACTIVE_HIGH>, /* 18: D18 P0.26 */
            <&gpio1  7 GPIO_ACTIVE_HIGH>; /* 19: D19 P1.07 */
    };

    glove0x0a_left_layout: glove0x0a_left_layout {
        compatible = "zmk,physical-layout";
        display-name = "Left";
        transform = <&left_transform>;
        kscan = <&kscan_left>;

        keys
            = <&key_physical_attrs 100 100    0    0       0     0     0>
            , <&key_physical_attrs 100 100  100    0       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400    0       0     0     0>
            , <&key_physical_attrs 100 100    0  100       0     0     0>
            , <&key_physical_attrs 100 100  100  100       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  100       0     0     0>
            , <&key_physical_attrs 100 100    0  200       0     0     0>
            , <&key_physical_attrs 100 100  100  200       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  200       0     0     0>
            , <&key_physical_attrs 100 100    0  300       0     0     0>
            , <&key_physical_attrs 100 100  100  300       0     0     0>
            , <&key_physical_attrs 100 100  200  300       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 200 100  400  300       0     0     0>
        ;
    };
};

/* D4/D5 が I2C0 に割り当てられている場合、内部 I2C を無効化して GPIO として使用する */
&i2c0 {
    status = "disabled";
};
