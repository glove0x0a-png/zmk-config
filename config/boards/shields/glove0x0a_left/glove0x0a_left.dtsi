#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/led/led.h>
/ {
    chosen {
        zmk,physical-layout = &glove0x0a_left_layout;
    };

    /* 左手: 20キー direct-scan */
    left_transform: matrix_transform_left {
        compatible = "zmk,matrix-transform";
        rows = <1>;
        columns = <20>;
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)
            RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)
            RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)
            RC(0,15) RC(0,16) RC(0,17) RC(0,18) RC(0,19)
        >;
    };

    kscan_left: kscan {
        compatible = "zmk,kscan-gpio-direct";
        wakeup-source;

        /* HIGH→LOW を押下とみなすため GPIO_ACTIVE_LOW を使用 */
        input-gpios =
         /*   <&gpio0 16 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, *//*  0: 表面上 P0.16 */
         /*   <&gpio1 00 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, *//*  0: 表面中 P1.00 */
            <&gpio1 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  0: 表面下 P1.10 */
            <&gpio0  2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  0: D0  P0.02 */
            <&gpio0  3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  1: D1  P0.03 */
            <&gpio0 28 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  2: D2  P0.28 */
            <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  3: D3  P0.29 */
            <&gpio0  4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  4: D4  P0.04 (I2C SDA) */
            <&gpio0  5 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  5: D5  P0.05 (I2C SCL) */
            <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  6: D6  P1.11 */
            <&gpio1 12 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  7: D7  P1.12 */
            <&gpio1 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  8: D8  P1.13 */
            <&gpio1 14 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /*  9: D9  P1.14 */
            <&gpio1 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 10: D10 P1.15 */
            <&gpio0  6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 11: D11 P0.06 */
            <&gpio0  7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 12: D12 P0.07 */
            <&gpio0  8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 13: D13 P0.08 */
            <&gpio0  9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 14: D14 P0.09 */
            <&gpio0 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 15: D15 P0.10 */
            <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 16: D16 P0.31 */
            <&gpio0 30 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 17: D17 P0.30 */
            <&gpio0 26 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>, /* 18: D18 P0.26 */
            <&gpio1  7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; /* 19: D19 P1.07 */
    };

    glove0x0a_left_layout: glove0x0a_left_layout {
        compatible = "zmk,physical-layout";
        display-name = "Left";
        transform = <&left_transform>;
        kscan = <&kscan_left>;

        keys
            = <&key_physical_attrs 100 100    0    0       0     0     0>
            , <&key_physical_attrs 100 100  100    0       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400    0       0     0     0>

            , <&key_physical_attrs 100 100    0  100       0     0     0>
            , <&key_physical_attrs 100 100  100  100       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  100       0     0     0>

            , <&key_physical_attrs 100 100    0  200       0     0     0>
            , <&key_physical_attrs 100 100  100  200       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  200       0     0     0>

            , <&key_physical_attrs 100 100    0  300       0     0     0>
            , <&key_physical_attrs 100 100  100  300       0     0     0>
            , <&key_physical_attrs 100 100  200  300       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 200 100  400  300       0     0     0>
        ;
    };
};

/* D4/D5 を GPIO として安全に使うための設定 */
&i2c0 {
    status = "disabled";

    /* default と sleep の 2 つが必要 */
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
};

&pinctrl {
    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
                    <NRF_PSEL(TWIM_SCL, 0, 5)>;
            bias-pull-up;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
                    <NRF_PSEL(TWIM_SCL, 0, 5)>;
            bias-pull-up;
        };
    };
};