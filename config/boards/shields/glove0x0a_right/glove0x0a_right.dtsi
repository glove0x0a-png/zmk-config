#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/led/led.h>
#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
//右手用-CENTER
/ {
    chosen {
        zmk,physical-layout = &glove0x0a_right_layout;
    };

    /* transform（右手 5×4） */
    right_transform: matrix_transform_right {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <5>;
        map = <
           RC( 0, 4) RC( 0, 5) RC( 0, 6) RC( 0, 7) RC(0, 8)
           RC( 1, 4) RC( 1, 5) RC( 1, 6) RC( 1, 7) RC(1, 8)
           RC( 2, 4) RC( 2, 5) RC( 2, 6) RC( 2, 7) RC(2, 8)
           RC( 3, 4) RC( 3, 5) RC( 3, 6) RC( 3, 7) RC(3, 8)
        >;
    };

   /* kscan（右手） */
    kscan_right: kscan {
        compatible = "zmk,kscan-gpio-charlieplex";
        interrupt-gpios = <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN) >;  /*D06*/
        wakeup-source;
        gpios
          =
            <&gpio0  2  GPIO_ACTIVE_HIGH> /*0:D00*/
          , <&gpio0  3  GPIO_ACTIVE_HIGH> /*1:D01*/
          , <&gpio0 28  GPIO_ACTIVE_HIGH> /*2:D02*/
          , <&gpio0 29  GPIO_ACTIVE_HIGH> /*3:D03*/
          , <&gpio1 12  GPIO_ACTIVE_HIGH> /*4:D07*/
          , <&gpio1 13  GPIO_ACTIVE_HIGH> /*5:D08*/
          , <&gpio1 14  GPIO_ACTIVE_HIGH> /*6:D09*/
          , <&gpio1 07  GPIO_ACTIVE_HIGH> /*7:D09-D10,D19*/
          , <&gpio1 15  GPIO_ACTIVE_HIGH> /*8:D10*/
        ;
    };

    /* physical-layout（右手 20キーだけ） */
    glove0x0a_right_layout: glove0x0a_right_layout {
        compatible = "zmk,physical-layout";
        display-name = "Right";
        transform = <&right_transform>;
        kscan = <&kscan_right>;

        keys  //                     w   h    x    y     rot    rx    ry
            = <&key_physical_attrs 100 100    0    0       0     0     0>
            , <&key_physical_attrs 100 100  100    0       0     0     0>
            , <&key_physical_attrs 100 100  200    0       0     0     0>
            , <&key_physical_attrs 100 100  300    0       0     0     0>
            , <&key_physical_attrs 100 100  400    0       0     0     0>
            , <&key_physical_attrs 100 100    0  100       0     0     0>
            , <&key_physical_attrs 100 100  100  100       0     0     0>
            , <&key_physical_attrs 100 100  200  100       0     0     0>
            , <&key_physical_attrs 100 100  300  100       0     0     0>
            , <&key_physical_attrs 100 100  400  100       0     0     0>
            , <&key_physical_attrs 100 100    0  200       0     0     0>
            , <&key_physical_attrs 100 100  100  200       0     0     0>
            , <&key_physical_attrs 100 100  200  200       0     0     0>
            , <&key_physical_attrs 100 100  300  200       0     0     0>
            , <&key_physical_attrs 100 100  400  200       0     0     0>
            , <&key_physical_attrs 100 100    0  300       0     0     0>
            , <&key_physical_attrs 100 100  100  300       0     0     0>
            , <&key_physical_attrs 100 100  200  300       0     0     0>
            , <&key_physical_attrs 100 100  300  300       0     0     0>
            , <&key_physical_attrs 200 100  400  300       0     0     0>
        ;
    };
};
/* I2C（右手のみ） */
&xiao_i2c {
    status = "okay";
};